generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------
// ENUMS
// ----------------------------------------------------

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  READY
  DISPATCHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TripPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum MaintenanceStatus {
  REQUESTED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
  EMERGENCY
  INSPECTION
  ROUTINE_SERVICE
}

enum MaintenancePriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum VehicleType {
  TRUCK
  VAN
  REFRIGERATED
  FLATBED
  MINI_TRUCK
  BUS
  OTHER
}
enum FuelType {
  DIESEL
  PETROL
  CNG
  LNG
  ELECTRIC
  OTHER
}

enum PaymentMethod {
  CASH
  CORPORATE_CARD
  FUEL_CARD
  BANK_TRANSFER
  CREDIT
  OTHER
}

enum FuelLogStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum ExpenseType {
  TOLL
  PARKING
  FINE
  MAINTENANCE
  FUEL
  OTHER
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PENDING_PAYMENT
  PROCESSING_PAYMENT
  PAID
  REJECTED
}

// ----------------------------------------------------
// MODELS
// ----------------------------------------------------

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  
  // Relations
  users       User[]

  // Audit
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("roles")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  isActive  Boolean  @default(true)
  
  // Relations
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)
  tripsCreated   Trip[] @relation("TripCreatedBy")
  tripsCompleted Trip[] @relation("TripCompletedBy")
  maintenanceReported  Maintenance[] @relation("MaintenanceReportedBy")
  maintenanceApproved  Maintenance[] @relation("MaintenanceApprovedBy")
  maintenanceCompleted Maintenance[] @relation("MaintenanceCompletedBy")
  maintenanceCancelled Maintenance[] @relation("MaintenanceCancelledBy")
  fuelLogsCreated      FuelLog[] @relation("FuelLogCreatedBy")
  fuelLogsApproved     FuelLog[] @relation("FuelLogApprovedBy")
  expensesCreated      Expense[] @relation("ExpenseCreatedBy")
  expensesApproved     Expense[] @relation("ExpenseApprovedBy")
  expensesPaid         Expense[] @relation("ExpensePaidBy")

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([email])
  @@index([roleId])
  @@map("users")
}

model Vehicle {
  id                 String        @id @default(uuid())
  registrationNumber String        @unique
  name               String
  model              String
  type               VehicleType
  fuelType           FuelType      @default(DIESEL)
  fuelTankCapacity   Float?
  maxLoadCapacity    Float         // In kg or tons
  odometer           Float         @default(0) // Current mileage
  acquisitionCost    Float
  status             VehicleStatus @default(AVAILABLE)
  
  // Soft Delete
  isDeleted          Boolean       @default(false)

  // Relations
  trips              Trip[]
  maintenanceLogs    Maintenance[]
  fuelLogs           FuelLog[]
  expenses           Expense[]

  // Audit
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([status])
  @@index([registrationNumber])
  @@map("vehicles")
}

model Driver {
  id                 String       @id @default(uuid())
  name               String
  licenseNumber      String       @unique
  licenseCategory    String
  licenseExpiryDate  DateTime
  contactNumber      String       @unique
  email              String       @unique
  address            String?
  safetyScore        Float        @default(100.0)
  status             DriverStatus @default(AVAILABLE)

  // Soft Delete
  isDeleted          Boolean      @default(false)

  // Relations
  trips              Trip[]
  fuelLogs           FuelLog[]

  // Audit
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([status])
  @@index([licenseNumber])
  @@map("drivers")
}

model Trip {
  id              String     @id @default(uuid())
  tripNumber      String     @unique
  source          String
  destination     String
  cargoWeight     Float
  plannedDistance Float
  status          TripStatus @default(DRAFT)
  priority        TripPriority @default(NORMAL)
  remarks         String?
  
  // Relations
  vehicleId       String
  vehicle         Vehicle    @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  
  driverId        String
  driver          Driver     @relation(fields: [driverId], references: [id], onDelete: Restrict)

  expenses        Expense[]
  fuelLogs        FuelLog[]

  // Realized Metrics
  plannedStartTime DateTime?
  plannedEndTime   DateTime?
  actualDistance  Float?
  startTime       DateTime?
  endTime         DateTime?

  // Audit Relations
  createdByUserId String?
  createdByUser   User?      @relation("TripCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  completedByUserId String?
  completedByUser   User?    @relation("TripCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)

  // Audit
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([status])
  @@index([vehicleId])
  @@index([driverId])
  @@index([plannedStartTime])
  @@map("trips")
}

model Maintenance {
  id                String            @id @default(uuid())
  maintenanceNumber String            @unique
  maintenanceType   MaintenanceType
  priority          MaintenancePriority @default(NORMAL)
  description       String
  estimatedCost     Float?
  actualCost        Float?
  vendor            String?
  technician        String?
  serviceDate       DateTime?
  nextServiceDate   DateTime?
  currentOdometer   Float
  remarks           String?
  attachments       Json?
  status            MaintenanceStatus @default(REQUESTED)
  
  // Relations
  vehicleId         String
  vehicle           Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  expenses          Expense[]

  // Audit Relations
  reportedByUserId  String
  reportedByUser    User              @relation("MaintenanceReportedBy", fields: [reportedByUserId], references: [id], onDelete: Restrict)
  approvedByUserId  String?
  approvedByUser    User?             @relation("MaintenanceApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  completedByUserId String?
  completedByUser   User?             @relation("MaintenanceCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)
  cancelledByUserId String?
  cancelledByUser   User?             @relation("MaintenanceCancelledBy", fields: [cancelledByUserId], references: [id], onDelete: SetNull)

  // Audit
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([vehicleId])
  @@index([status])
  @@index([maintenanceType])
  @@index([serviceDate])
  @@map("maintenance_logs")
}

model FuelLog {
  id                String          @id @default(uuid())
  fuelLogNumber     String          @unique
  status            FuelLogStatus   @default(DRAFT)
  fuelType          FuelType
  fuelStation       String?
  vendor            String?
  receiptNumber     String?
  paymentMethod     PaymentMethod?
  pricePerLiter     Float
  totalCost         Float
  liters            Float
  odometer          Float
  filledAt          DateTime
  remarks           String?
  attachments       Json?
  isDeleted         Boolean         @default(false)
  
  // Relations
  vehicleId         String
  vehicle           Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  tripId            String?
  trip              Trip?           @relation(fields: [tripId], references: [id], onDelete: SetNull)
  driverId          String?
  driver            Driver?         @relation(fields: [driverId], references: [id], onDelete: SetNull)

  // Audit Relations
  createdByUserId   String
  createdByUser     User            @relation("FuelLogCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  approvedByUserId  String?
  approvedByUser    User?           @relation("FuelLogApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  // Audit
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  submittedAt       DateTime?
  approvedAt        DateTime?
  rejectedAt        DateTime?

  @@index([vehicleId])
  @@index([tripId])
  @@index([filledAt])
  @@index([status])
  @@index([isDeleted])
  @@unique([vehicleId, filledAt, receiptNumber])
  @@map("fuel_logs")
}

model Expense {
  id               String        @id @default(uuid())
  expenseNumber    String        @unique
  status           ExpenseStatus @default(DRAFT)
  type             ExpenseType
  amount           Float
  date             DateTime      @default(now())
  description      String?
  vendor           String?
  receiptNumber    String?
  rejectionReason  String?
  paymentReference String?
  isDeleted        Boolean       @default(false)
  
  // Relations
  vehicleId     String?
  vehicle       Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  tripId        String?
  trip          Trip?    @relation(fields: [tripId], references: [id], onDelete: SetNull)

  maintenanceId String?
  maintenance   Maintenance? @relation(fields: [maintenanceId], references: [id], onDelete: SetNull)

  attachments   Json?

  // Audit Relations
  createdByUserId  String
  createdByUser    User          @relation("ExpenseCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  approvedByUserId String?
  approvedByUser   User?         @relation("ExpenseApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  paidByUserId     String?
  paidByUser       User?         @relation("ExpensePaidBy", fields: [paidByUserId], references: [id], onDelete: SetNull)

  // Audit & SLA Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  submittedAt DateTime?
  approvedAt  DateTime?
  rejectedAt  DateTime?
  paidAt      DateTime?

  @@index([vehicleId])
  @@index([tripId])
  @@index([date])
  @@index([status])
  @@index([isDeleted])
  @@index([vendor, date, amount])
  @@map("expenses")
}